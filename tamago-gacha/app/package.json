{
  "name": "tamago-gacha",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "子ども向けタマゴガチャ（カプセルトイ）ゲーム。タップ→ガタガタ→パカッ→モノが生まれる演出重視の作品。",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "deploy": "npm run build && node scripts/copy-dist.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
